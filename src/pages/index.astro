---
import Layout from "../layouts/Layout.astro";
import ProductCard from "../components/ProductCard.astro";
import FilterTabs from "../components/FilterTabs.svelte";
import Carousel from "../components/Carousel.astro";
import { Image } from "astro:assets";

import { LAMPS } from "../data";
import { Variant } from "../types";

const carouselLamps = LAMPS.filter((l) => l.images.length > 0);

const tabs = Object.values(Variant)
    .map((value) => ({
        value,
        label: value,
        count: LAMPS.filter((l) => l.variant === value && l.images.length > 0)
            .length,
    }))
    .filter((t) => t.count > 0)
    .sort((a, b) => b.count - a.count);

const wasabiIndex = LAMPS.findIndex(
    (l) => l.variant === Variant.jubi_ph5 && l.name === "Wasabi",
);
const wasabi = LAMPS[wasabiIndex];
---

<Layout title="Morfar's Lamper">
    <main class="pt-24 pb-24 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
        {/* Page header */}
        <div class="mb-16 flex flex-col gap-4">
            <div
                class="flex flex-col gap-8 md:gap-0 md:flex-row md:items-end justify-between"
            >
                <h1
                    class="font-din text-5xl md:text-6xl text-charcoal leading-tight max-w-lg"
                >
                    <div class="flex flex-col gap-2">
                        <div>Restaurerede</div>
                        <div class="text-brass">designklassikere</div>
                    </div>
                </h1>
                <p
                    class="text-mid max-w-sm leading-relaxed text-sm md:text-base"
                >
                    Hver lampe er håndplukket og omhyggeligt restaureret til sin
                    originale pragt — klar til at lyse op i dit hjem.
                </p>
            </div>
            <div class="w-16 h-px bg-brass/40 mt-2"></div>
        </div>

        {/* Image carousel strip */}
        <div class="-mx-4 sm:-mx-6 lg:-mx-8 mb-16 h-52">
            <Carousel>
                {
                    carouselLamps.map((lamp, i) => (
                        <a
                            href={`/lamps/${LAMPS.indexOf(lamp)}`}
                            class="group shrink-0 relative h-44 w-44 overflow-hidden rounded-xl border border-brass/15 hover:border-brass/40 transition-all duration-500 hover:shadow-lg hover:shadow-brass/10 hover:-translate-y-1"
                        >
                            <Image
                                src={lamp.images[0]!}
                                alt={`${lamp.variant} ${lamp.name}`}
                                width={200}
                                class="w-full h-full object-cover object-center grayscale-20 group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700 ease-out"
                            />
                            <div class="absolute inset-0 bg-linear-to-t from-charcoal/50 via-transparent to-transparent" />
                            <span class="absolute bottom-2 left-3 right-3 text-cream text-xs font-medium leading-tight truncate">
                                {lamp.name}
                            </span>
                        </a>
                    ))
                }
            </Carousel>
        </div>

        {/* Featured card */}

        <!-- <div class="hidden md:block">
            <div class="hidden md:flex items-center gap-4 mb-8">
                <span
                    class="text-brass text-xs font-medium uppercase tracking-[0.25em]"
                    >Udvalgt</span
                >
                <div class="flex-1 h-px bg-brass/20"></div>
            </div>
            <div class="mb-16">
                <ProductCard
                    image={wasabi.images[0]!}
                    title={wasabi.name}
                    href={`/lamps/${wasabiIndex}`}
                    subtitle={wasabi.variant}
                    description="En sjælden jubilæumsudgave af PH 5 i den karakteristiske wasabi-grønne farve — restaureret og klar til et nyt hjem."
                    designer={wasabi.designer}
                    variant="featured"
                />
            </div>
        </div> -->

        <div class="flex items-center gap-4 mb-8">
            <span
                class="text-brass text-xs font-medium uppercase tracking-[0.25em]"
                >Udforsk sortimentet</span
            >
            <div class="flex-1 h-px bg-brass/20"></div>
        </div>

        {/* Filter tabs */}
        <FilterTabs {tabs} client:load />

        {/* Grid of cards */}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
            {
                LAMPS.map((lamp, lampIndex) => {
                    const [image] = lamp.images;
                    if (!image) return;

                    const title = `${lamp.variant} ${lamp.name}`;
                    2023;
                    return (
                        <div class="lamp-card" data-variant={lamp.variant}>
                            <ProductCard
                                image={image}
                                title={title}
                                href={`/lamps/${lampIndex}`}
                                colors={lamp.colors}
                                designer={lamp.designer}
                            />
                        </div>
                    );
                })
            }
        </div>

        {/* Bottom CTA strip */}
        <div
            class="mt-16 rounded-2xl bg-warm-white border border-brass/20 p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-6 relative overflow-hidden"
        >
            <div class="absolute inset-0 pointer-events-none">
                <div
                    class="absolute -top-12 -right-12 w-64 h-64 bg-brass/8 rounded-full blur-3xl"
                >
                </div>
                <div
                    class="absolute -bottom-8 -left-8 w-48 h-48 bg-brass/5 rounded-full blur-2xl"
                >
                </div>
            </div>
            <div class="relative flex flex-col gap-2 text-center md:text-left">
                <span
                    class="text-brass text-xs uppercase tracking-[0.2em] font-medium"
                    >Har du en lampe?</span
                >
                <p class="text-2xl md:text-3xl text-charcoal">
                    Vi restaurerer også din lampe
                </p>
                <p class="text-mid text-sm max-w-md">
                    Send os billeder og få et uforpligtende tilbud på
                    restaurering af din gamle designlampe.
                </p>
            </div>
            <a
                href="mailto:pnentreprise@outlook.dk"
                class="relative shrink-0 inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-brass hover:bg-brass-light text-cream font-medium text-sm transition-all duration-300 hover:-translate-y-0.5 shadow-lg shadow-brass/20"
            >
                Få et tilbud
                <svg
                    class="w-4 h-4"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
                </svg>
            </a>
        </div>
    </main>
</Layout>

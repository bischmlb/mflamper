---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import Hero from "../assets/about_hero.jpg";
import Hero1 from "../assets/about_img1.jpg";
import Hero2 from "../assets/about_img2.jpg";
---

<Layout title="Om os — Morfar's Lamper">
    <main class="pt-24 pb-24 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
        {/* Page header */}
        <div class="mb-16 flex flex-col gap-4">
            <div
                class="flex flex-col gap-8 md:gap-0 md:flex-row md:items-end justify-between"
            >
                <h1
                    class="font-din text-5xl md:text-6xl text-charcoal leading-tight max-w-lg"
                >
                    <div class="flex flex-col gap-2">
                        <div>Håndværk med</div>
                        <div class="text-brass">respekt for historien</div>
                    </div>
                </h1>
                <p
                    class="text-mid max-w-sm leading-relaxed text-sm md:text-base"
                >
                    Vi vækker danske designklassikere til live — med dyb respekt
                    for det oprindelige håndværk og de designere, der skabte
                    dem.
                </p>
            </div>
            <div class="w-16 h-px bg-brass/40 mt-2"></div>
        </div>

        {/* Hero image */}
        <div class="relative overflow-hidden rounded-2xl h-[60vh] mb-20">
            <Image
                src={Hero}
                alt="Morfar's Lamper værksted"
                width={1400}
                class="w-full h-full object-cover object-center grayscale"
            />
            <div
                class="absolute inset-0 bg-linear-to-t from-charcoal/40 via-transparent to-transparent"
            >
            </div>
        </div>

        {/* Story section */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 mb-24 items-center">
            <div class="flex flex-col gap-6">
                <div>
                    <span
                        class="text-brass text-xs font-medium uppercase tracking-[0.25em] block mb-4"
                    >
                        Historien
                    </span>
                    <h2
                        class="font-din text-3xl md:text-4xl text-charcoal leading-tight mb-6"
                    >
                        Manden bag lamperne
                    </h2>
                    <div
                        class="flex flex-col gap-4 text-mid leading-relaxed text-sm md:text-base"
                    >
                        <p>
                            Bag Morfar's Lamper står Jan Lyhne — en passioneret
                            håndværker med et skarpt øje for de klassiske danske
                            designlamper. Det startede som en hobby, men er
                            vokset til noget langt større: et dedikeret arbejde
                            med at redde og restaurere lamper, der ellers ville
                            gå tabt.
                        </p>
                        <p>
                            Jan har specialiseret sig i PH-lamperne fra Poul
                            Henningsen og AJ Royal 500 fra Arne Jacobsen — to af
                            de mest ikoniske lamper i dansk designhistorie. Hver
                            lampe behandles med den samme omhu og respekt, som
                            den fortjener.
                        </p>
                    </div>
                </div>
            </div>
            <div
                class="relative overflow-hidden rounded-2xl h-96 shadow-xl shadow-charcoal/10"
            >
                <Image
                    src={Hero2}
                    alt="Detalje af restaureret lampe"
                    width={800}
                    class="w-full h-full object-cover object-center"
                />
            </div>
        </div>

        {/* Values section */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-16 mb-24 items-center">
            <div
                class="relative overflow-hidden rounded-2xl h-96 order-2 md:order-1 shadow-xl shadow-charcoal/10"
            >
                <Image
                    src={Hero1}
                    alt="Jan Lyhne restaurerer lamper"
                    width={800}
                    class="w-full h-full object-cover object-center"
                />
            </div>
            <div class="flex flex-col gap-6 order-1 md:order-2">
                <span
                    class="text-brass text-xs font-medium uppercase tracking-[0.25em]"
                >
                    Værdier
                </span>
                <h2
                    class="font-din text-3xl md:text-4xl text-charcoal leading-tight"
                >
                    Autenticitet frem for alt
                </h2>
                <div
                    class="flex flex-col gap-4 text-mid leading-relaxed text-sm md:text-base"
                >
                    <p>
                        Det er ikke bare en lampe. Det er et stykke dansk
                        designhistorie, skabt af navne som Poul Henningsen og
                        Arne Jacobsen — designere, der tænkte i lys, skygge og
                        proportioner på en måde, der stadig er uovertruffet.
                    </p>
                    <p>
                        Hos Morfar's Lamper tror vi på, at disse klassikere
                        fortjener et nyt liv frem for at ende på loftet. Hver
                        restaurering er en hyldest til det originale håndværk.
                    </p>
                </div>
                <div
                    class="grid grid-cols-2 gap-6 pt-4 border-t border-brass/15"
                >
                    <div>
                        <p class="font-din text-3xl text-charcoal">100+</p>
                        <p
                            class="text-mid text-xs uppercase tracking-widest mt-1"
                        >
                            Restaurerede lamper
                        </p>
                    </div>
                    <div>
                        <p class="font-din text-3xl text-charcoal">2023</p>
                        <p
                            class="text-mid text-xs uppercase tracking-widest mt-1"
                        >
                            Grundlagt
                        </p>
                    </div>
                </div>
            </div>
        </div>

        {/* CTA strip */}
        <div
            class="rounded-2xl bg-warm-white border border-brass/20 p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-6 relative overflow-hidden"
        >
            <div class="absolute inset-0 pointer-events-none">
                <div
                    class="absolute -top-12 -right-12 w-64 h-64 bg-brass/8 rounded-full blur-3xl"
                >
                </div>
                <div
                    class="absolute -bottom-8 -left-8 w-48 h-48 bg-brass/5 rounded-full blur-2xl"
                >
                </div>
            </div>
            <div class="relative flex flex-col gap-2 text-center md:text-left">
                <span
                    class="text-brass text-xs uppercase tracking-[0.2em] font-medium"
                    >Kom i kontakt</span
                >
                <p class="text-2xl md:text-3xl text-charcoal">
                    Har du en lampe, der trænger til kærlighed?
                </p>
                <p class="text-mid text-sm max-w-md">
                    Send os billeder og få et uforpligtende tilbud på
                    restaurering af din gamle designlampe.
                </p>
            </div>
            <div class="relative shrink-0 flex flex-col sm:flex-row gap-3">
                <a
                    href="mailto:pnentreprise@outlook.dk"
                    class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-brass hover:bg-brass-light text-cream font-medium text-sm transition-all duration-300 hover:-translate-y-0.5 shadow-lg shadow-brass/20"
                >
                    Send en mail
                    <svg
                        class="w-4 h-4"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
                    </svg>
                </a>
                <a
                    href="tel:+4540518033"
                    class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border border-brass/30 hover:border-brass/60 text-charcoal font-medium text-sm transition-all duration-300 hover:-translate-y-0.5"
                >
                    Ring til os
                </a>
            </div>
        </div>
    </main>
</Layout>

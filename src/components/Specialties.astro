---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Button from "./Button.astro";

const allSpecialties = await getCollection("specialties");
const sortedSpecialties = allSpecialties.sort(
    (a, b) => a.data.order - b.data.order,
);
---

<div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
    {
        sortedSpecialties.map(async (item) => {
            const { Content } = await render(item);

            return (
                <article class="group flex flex-col md:flex-row max-h-125 lg:max-h-100 bg-mid shadow-lg overflow-hidden rounded-lg">
                    <div class="w-full md:w-1/2 overflow-hidden relative">
                        <Image
                            src={item.data.image}
                            alt={item.data.alt}
                            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                        />
                        <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors" />
                    </div>

                    <div class="w-full md:w-1/2 p-8 flex flex-col justify-center items-start text-primary">
                        <div class="text-xl mb-4 text-white font-medium">
                            {item.data.title}
                        </div>
                        <div class="md:text-base text-gray-300 mb-6 font-light">
                            <Content />
                        </div>

                        <Button
                            href={item.data.linkTo}
                            class="mt-auto self-end text-sm"
                            variant="light"
                        >
                            {item.data.buttonText}
                        </Button>
                    </div>
                </article>
            );
        })
    }
</div>

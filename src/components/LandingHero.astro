---
import { Image } from "astro:assets";
import Hero from "../assets/hero.jpg";
import Button from "./Button.astro";
---

<div class="w-full relative">
    <div
        class="relative w-full h-svh md:h-[75vh] overflow-hidden group p-0 bg-cream"
    >
        <div class="relative h-full w-full overflow-hidden rounded-b-2xl">
            <Image
                src={Hero}
                alt="Descriptive alt text is required"
                fetchpriority="high"
                loading="eager"
                quality={100}
                class="w-full h-full object-cover object-center grayscale-100"
            />

            <div
                class="absolute inset-0 bg-linear-to-r from-black/65 to-black/50"
            >
            </div>
        </div>

        <div class="absolute inset-0 flex flex-col px-8 mx-auto">
            <div
                class="relative h-full w-full rounded-xl p-4 flex flex-col md:pr-[35%] gap-8"
            >
                <div
                    class="w-full flex flex-col h-full rounded-2xl gap-4 p-4 justify-center md:justify-center md:pt-80"
                >
                    <!-- <Logo
                        alt="Birch & Co"
                        class="w-40 md:w-54 lg:w-60 text-birch-mist mt-0 md:my-0 self-center drop-shadow-lg"
                        client:load
                    /> -->

                    <div
                        class="text-7xl text-cream self-center drop-shadow-lg font-din mr-auto"
                    >
                        <span class="text-brass text-shadow-lg">
                            Morfar's
                        </span>
                        Lamper
                    </div>
                    <!-- <p class="text-cream text-xl tracking-wider">
                        Vi vækker danske designklassikere til live. Uanset om
                        det er en PH 4/5, et tidløst Arne Jacobsen-design eller
                        en helt tredje lampe, restaurerer vi den med dyb respekt
                        for det oprindelige håndværk. Gå også på opdagelse i
                        vores eksklusive kollektion af færdigrestaurerede
                        lamper, klar til at sprede nyt lys i dit hjem.
                    </p> -->

                    <div
                        class="gap-4 flex justify-start mt-4 text-md items-center"
                    >
                        <Button> Se lamperne </Button>
                        <Button id="open-contact">
                            <span class="font-medium tracking-wide"
                                >Kontakt os</span
                            >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="2"
                                stroke="currentColor"
                                class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
                                ></path>
                            </svg>
                        </Button>
                    </div>

                    <div
                        id="contact-modal"
                        class="fixed inset-0 z-50 flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300"
                        aria-hidden="true"
                    >
                        <div
                            id="modal-backdrop"
                            class="absolute inset-0 bg-black/60 backdrop-blur-md transition-all"
                        >
                        </div>

                        <div
                            class="relative bg-stone-900/80 border border-birch-oak/20 p-8 rounded-2xl shadow-2xl max-w-sm w-full mx-4 transform scale-95 transition-transform duration-300"
                            id="modal-card"
                        >
                            <button
                                id="close-contact"
                                class="absolute top-4 right-4 text-birch-mist/50 hover:text-birch-mist hover:rotate-90 transition-all"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke-width="2"
                                    stroke="currentColor"
                                    class="w-6 h-6"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M6 18 18 6M6 6l12 12"></path>
                                </svg>
                            </button>

                            <div class="text-center mb-8">
                                <h3
                                    class="text-2xl font-serif text-birch-mist mb-2"
                                >
                                    Kontakt os
                                </h3>
                                <p class="text-sm text-birch-mist/70">
                                    Vi er klar til at hjælpe med dit næste
                                    projekt.
                                </p>
                            </div>

                            <div class="flex flex-col gap-4">
                                <a
                                    href="tel:22102324"
                                    class="group flex items-center gap-4 p-4 rounded-xl bg-white/5 hover:bg-birch-oak/20 border border-transparent hover:border-birch-oak/30 transition-all"
                                >
                                    <div
                                        class="p-2 rounded-full bg-birch-oak/20 text-birch-oak group-hover:bg-birch-oak group-hover:text-white transition-colors"
                                    >
                                        <svg
                                            class="w-6 h-6"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                            ><path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                                            ></path></svg
                                        >
                                    </div>
                                    <div class="flex flex-col text-left">
                                        <span
                                            class="text-xs text-birch-mist/60 uppercase tracking-wider"
                                            >Ring til os</span
                                        >
                                        <span
                                            class="text-lg text-birch-mist font-medium"
                                            >22 10 23 24</span
                                        >
                                    </div>
                                </a>

                                <a
                                    href="mailto:post@birch-co.dk"
                                    class="group flex items-center gap-4 p-4 rounded-xl bg-white/5 hover:bg-birch-oak/20 border border-transparent hover:border-birch-oak/30 transition-all"
                                >
                                    <div
                                        class="p-2 rounded-full bg-birch-oak/20 text-birch-oak group-hover:bg-birch-oak group-hover:text-white transition-colors"
                                    >
                                        <svg
                                            class="w-6 h-6"
                                            fill="none"
                                            stroke="currentColor"
                                            viewBox="0 0 24 24"
                                            xmlns="http://www.w3.org/2000/svg"
                                            ><path
                                                stroke-linecap="round"
                                                stroke-linejoin="round"
                                                stroke-width="2"
                                                d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.207"
                                            ></path></svg
                                        >
                                    </div>
                                    <div class="flex flex-col text-left">
                                        <span
                                            class="text-xs text-birch-mist/60 uppercase tracking-wider"
                                            >Send en mail</span
                                        >
                                        <span
                                            class="text-lg text-birch-mist font-medium"
                                            >post@birch-co.dk</span
                                        >
                                    </div>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const video = document.getElementById("hero-video") as HTMLVideoElement;

        if (video) {
            video.playbackRate = 0.8;
        }

        const modal = document.getElementById("contact-modal");
        const openBtn = document.getElementById("open-contact");
        const closeBtn = document.getElementById("close-contact");
        const backdrop = document.getElementById("modal-backdrop");
        const card = document.getElementById("modal-card");

        function toggleModal(show: boolean) {
            if (show) {
                modal?.classList.remove("opacity-0", "pointer-events-none");
                // Small timeout to allow the transition to trigger
                setTimeout(() => {
                    card?.classList.remove("scale-95");
                    card?.classList.add("scale-100");
                }, 10);
            } else {
                card?.classList.remove("scale-100");
                card?.classList.add("scale-95");
                modal?.classList.add("opacity-0", "pointer-events-none");
            }
        }

        openBtn?.addEventListener("click", () => toggleModal(true));
        closeBtn?.addEventListener("click", () => toggleModal(false));
        backdrop?.addEventListener("click", () => toggleModal(false));
    </script>
</div>

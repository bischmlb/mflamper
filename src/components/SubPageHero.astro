---
import type { ImageMetadata } from "astro";
import type { HTMLAttributes } from "astro/types";
import { Image } from "astro:assets";

interface Props extends HTMLAttributes<"section"> {
    title: string;
    subtitle?: string;
    image?: ImageMetadata;
    imageAlt?: string;
    ctaText?: string;
    ctaLink?: string;
    secondaryCtaText?: string;
    secondaryCtaLink?: string;
}

const {
    title,
    subtitle,
    image,
    imageAlt = "Birch & Co tømrerarbejde",
    ctaText = "Kontakt",
    ctaLink = "/kontakt",
    secondaryCtaText,
    secondaryCtaLink,
    class: className,
    ...rest
} = Astro.props;

const hasContent = Astro.slots.has("default");
---

<section
    class:list={[
        "relative top-16 pt-10 md:pt-20 pb-16 px-4 sm:px-6 lg:px-8 bg-primary",
        className,
    ]}
    {...rest}
>
    <div class="max-w-7xl mx-auto">
        <div
            class="group relative overflow-hidden grid grid-cols-1 md:grid-cols-2 min-h-100 md:gap-12"
        >
            <div
                class="text-left relative z-10 p-2 pb-0 flex flex-col justify-start md:justify-center h-full order-2 lg:order-1"
            >
                <h1
                    class="font-serif text-5xl md:text-6xl mid leading-[1.1] tracking-tight mb-6 md:mb-10"
                >
                    {title}
                </h1>

                {
                    hasContent && (
                        <div class="relative font-din text-lg mid leading-relaxed mb-8 md:max-w-sm lg:max-w-lg">
                            <slot />
                            <div class="after:content-[''] after:absolute after:-top-2 md:after:-top-4.5 md:after:left-0 md:after:translate-x-0 after:h-0.5 after:w-12 after:bg-primary" />
                        </div>
                    )
                }
            </div>

            {
                image && (
                    <div class="relative items-center flex flex-col rounded-3xl min-h-72 h-full w-full order-2 overflow-hidden">
                        <Image
                            src={image}
                            alt={imageAlt}
                            loading="eager"
                            fetchpriority="high"
                            class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                        />
                    </div>
                )
            }
        </div>
    </div>
</section>

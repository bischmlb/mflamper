---
interface Props {
    title: string;
    description?: string;
    class?: string;
}

const { title, description, class: className } = Astro.props;
---

<div class:list={["mb-12 md:text-center max-w-2xl mx-auto", className]}>
    <h2 class="text-3xl md:text-4xl font-light text-mid mb-4 tracking-tight">
        {title}
    </h2>

    {description && <p class="text-lg text-gray-600">{description}</p>}
</div>
